{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/build_web.sh",
  "outputDirectory": "flutter_app/build/web",
  "installCommand": "echo skip",
  "functions": {
    "api/index.py": { "runtime": "@vercel/python@4.3.1" }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/v1/(.*)", "destination": "/api/index" }
  ]
}
